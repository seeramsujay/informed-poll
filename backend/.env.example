GEMINI_API_KEY=your_gemini_api_key_here
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json
PORT=8080
# FIRESTORE_PROJECT_ID=your-project-id

# CORS: comma-separated list of allowed origins (restrict in production)
# Example: ALLOWED_ORIGINS=https://your-app.run.app,https://yourdomain.com
# Leave unset to allow all origins (NOT recommended for production)
ALLOWED_ORIGINS=https://your-frontend-url.run.app

# Rate limiting: requests per IP per minute (default: 30)
RATE_LIMIT_PER_MINUTE=30

# LanceDB path for RAG context
LANCE_DB_PATH=./lancedb/poll_context
